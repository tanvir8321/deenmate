{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "attribution": {},
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(composer install*)",
      "Bash(composer require *)",
      "Bash(composer dump-autoload*)",
      "Bash(composer dev*)",
      "Bash(composer run *)",
      "Bash(php artisan make:*)",
      "Bash(php artisan migrate)",
      "Bash(php artisan migrate --*)",
      "Bash(php artisan db:seed*)",
      "Bash(php artisan test*)",
      "Bash(php artisan route:*)",
      "Bash(php artisan config:*)",
      "Bash(php artisan cache:*)",
      "Bash(php artisan queue:*)",
      "Bash(php artisan horizon*)",
      "Bash(php artisan tinker*)",
      "Bash(php artisan lang:*)",
      "Bash(php artisan webpush:*)",
      "Bash(php -v)",
      "Bash(php -l *)",
      "Bash(./vendor/bin/pint*)",
      "Bash(./vendor/bin/phpstan*)",
      "Bash(./vendor/bin/pest*)",
      "Bash(pnpm install*)",
      "Bash(pnpm add *)",
      "Bash(pnpm lint*)",
      "Bash(pnpm format*)",
      "Bash(pnpm build*)",
      "Bash(pnpm dev*)",
      "Bash(pnpm test*)",
      "Bash(npm run *)",
      "Bash(npx vite*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout -b *)",
      "Bash(git checkout *)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git restore *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(touch *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(docker compose up*)",
      "Bash(docker compose down)",
      "Bash(docker compose ps*)",
      "Bash(docker compose logs*)",
      "Bash(docker compose exec *)",
      "WebFetch(domain:laravel.com)",
      "WebFetch(domain:inertiajs.com)",
      "WebFetch(domain:react.dev)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:pestphp.com)",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/12-06-2026?latitude=23.8103&longitude=90.4125&method=1&school=1&timezonestring=Asia/Dhaka\")",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/12-06-2026?latitude=51.5074&longitude=-0.1278&method=2&school=0&timezonestring=Europe/London\")",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/12-06-2026?latitude=-6.2088&longitude=106.8456&method=3&school=0&timezonestring=Asia/Jakarta\")",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/15-01-2026?latitude=23.8103&longitude=90.4125&method=1&school=1&timezonestring=Asia/Dhaka\")",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/15-01-2026?latitude=51.5074&longitude=-0.1278&method=2&school=0&timezonestring=Europe/London\")",
      "Bash(curl -s \"https://api.aladhan.com/v1/timings/15-01-2026?latitude=-6.2088&longitude=106.8456&method=3&school=0&timezonestring=Asia/Jakarta\")"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(chmod 777 *)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.production)",
      "Edit(.env)",
      "Edit(.env.production)"
    ],
    "ask": [
      "Bash(git push*)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(rm *)",
      "Bash(composer remove *)",
      "Bash(composer update*)",
      "Bash(pnpm remove *)",
      "Bash(php artisan migrate:fresh*)",
      "Bash(php artisan migrate:reset*)",
      "Bash(php artisan migrate:rollback*)",
      "Bash(php artisan db:wipe*)",
      "Bash(docker compose down -v*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -x ./vendor/bin/pint ]; then ./vendor/bin/pint --dirty --quiet 2>/dev/null || true; fi"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Reminder: run php artisan test, ./vendor/bin/pint and ./vendor/bin/phpstan analyse before considering the task done (see CLAUDE.md Definition of Done).'"
          }
        ]
      }
    ]
  }
}
