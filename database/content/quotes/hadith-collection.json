{
    "version": 1,
    "quotes": [
        {
            "id": "bukhari-5027",
            "arabic": "\u062e\u064a\u0631\u0643\u0645 \u0645\u0646 \u062a\u0639\u0644\u0645 \u0627\u0644\u0642\u0631\u0622\u0646 \u0648\u0639\u0644\u0645\u0647",
            "transliteration": "Khayrukum man ta'allamal-Qur'ana wa 'allamahu.",
            "translation": {
                "en": "The best of you are those who learn the Quran and teach it.",
                "bn": "\u09a4\u09cb\u09ae\u09be\u09a6\u09c7\u09b0 \u09ae\u09a7\u09cd\u09af\u09c7 \u09b8\u09c7\u09b0\u09be \u09af\u09bf\u09a8\u09be \u0995\u09cb\u09b0\u0986\u09a8 \u09b6\u09bf\u0996\u09c7 \u0993 \u09b6\u09bf\u0996\u09be\u09df\u0964",
                "ar": "\u062e\u064a\u0631\u0643\u0645 \u0645\u0646 \u062a\u0639\u0644\u0645 \u0627\u0644\u0642\u0631\u0622\u0646 \u0648\u0639\u0644\u0645\u0647",
                "ur": "\u062a\u0645 \u0645\u06cc\u06ba \u0633\u06d2 \u0628\u06c1\u062a\u0631 \u0648\u06c1 \u062c\u0648 \u0642\u0631\u0622\u0646 \u0633\u06cc\u06ba\u06a9\u06be \u0627\u0648\u0631 \u0633\u06a9\u06be\u0626\u06d2",
                "tr": "Sizin en hay\u0131rl\u0131n\u0131z Kuran'\u0131 \u00f6\u011frenen ve \u00f6\u011fretenlerdir.",
                "id": "Sebaik-baik kalian adalah yang mempelajari Al-Qur'an dan mengajarkannya."
            },
            "source": "Sahih al-Bukhari 5027"
        }
    ]
}
